# VYRONIX Standard Library: IO Module

unit write(msg: str): void
    echo msg

unit print(msg: str): void
    echo msg

unit input(prompt: str): str
    give ask prompt

unit read(): str
    give ask ""

unit ask_int(prompt: str): int
    let s = ask prompt
    give str_to_int(s)

unit ask_float(prompt: str): float
    let s = ask prompt
    give str_to_float(s)
