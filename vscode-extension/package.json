{
    "name": "vyronix-vscode",
    "displayName": "VYRONIX Language Support",
    "description": "Syntax highlighting and language support for VYRONIX (.vx)",
    "version": "0.1.0",
    "publisher": "vyronix-team",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "vyronix",
            "aliases": ["VYRONIX", "vyronix"],
            "extensions": [".vx"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "vyronix",
            "scopeName": "source.vx",
            "path": "./syntaxes/vyronix.tmLanguage.json"
        }],
        "snippets": [{
            "language": "vyronix",
            "path": "./snippets.json"
        }]
    }
}
