{
  "name": "vyronix",
  "displayName": "VYRONIX",
  "description": "Professional support for the VYRONIX programming language",
  "version": "1.0.0",
  "publisher": "vyronix-engineering",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vyronix.run",
        "title": "Run VYRONIX File",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vyronix.run",
          "group": "navigation",
          "when": "resourceExtname == .vx"
        }
      ]
    },
    "debuggers": [
      {
        "type": "vyronix-debug",
        "label": "VYRONIX Debugger",
        "program": "./dist/debugAdapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [ "program" ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the VYRONIX file.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch.",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "vyronix-debug",
            "request": "launch",
            "name": "Launch VYRONIX",
            "program": "${file}",
            "stopOnEntry": true
          }
        ]
      }
    ],
    "languages": [{
      "id": "vyronix",
      "aliases": ["VYRONIX", "vyronix"],
      "extensions": [".vx", ".vyx"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "vyronix",
      "scopeName": "source.vx",
      "path": "./syntaxes/vyronix.tmLanguage.json"
    }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.2"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.4"
  }
}
