{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "VYRONIX",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#types"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.vyronix",
				"match": "\\b(if|else|elif|for|to|step|while|loop|match|case|default|try|catch|throw|return|break|continue|import|use|module|export|call)\\b"
			},
			{
				"name": "keyword.other.vyronix",
				"match": "\\b(let|const|var|fn|proc|struct|enum|any)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.vyronix",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.vyronix",
					"match": "\\\\."
				},
				{
					"name": "variable.interpolation.vyronix",
					"begin": "\\{",
					"end": "\\}",
					"patterns": [
						{
							"include": "$self"
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.vyronix",
					"match": "//.*$"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.vyronix",
					"match": "\\b\\d+(\\.\\d+)?\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.vyronix",
					"match": "\\b(true|false|null)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.vyronix",
					"match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|int|float|str|string|bool|void|array)\\b"
				}
			]
		}
	},
	"scopeName": "source.vx"
}
