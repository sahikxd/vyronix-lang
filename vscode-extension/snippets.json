{
    "Function Definition": {
        "prefix": "fn",
        "body": [
            "fn ${1:name}(${2:params}) -> ${3:i64} {",
            "    $0",
            "}"
        ],
        "description": "Define a new function"
    },
    "Main Function": {
        "prefix": "main",
        "body": [
            "fn main() -> void {",
            "    $0",
            "}"
        ],
        "description": "Main entry point"
    },
    "Print to Console": {
        "prefix": "print",
        "body": [
            "print(${1:\"hello\"});"
        ],
        "description": "Print value to standard output"
    },
    "If Statement": {
        "prefix": "if",
        "body": [
            "if (${1:condition}) {",
            "    $0",
            "}"
        ],
        "description": "Conditional statement"
    }
}
