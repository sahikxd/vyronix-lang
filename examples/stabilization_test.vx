import time

# 1. Test Recursion Limit (Should error gracefully, not crash)
unit test_recursion(n: int): int
    give test_recursion(n + 1)

# 2. Test Exception Handling & Unwinding
unit test_exceptions(): void
    try:
        echo "Inside try block"
        let x = 1 / 0  # Should trigger division by zero error
    catch err:
        echo "Caught error: " + err
    echo "Resumed after catch"

# 3. Test Deep GC Marking
class Node:
    init(v: int):
        set self.val = v
        set self.next = null

unit test_gc(): void
    let head = new Node(0)
    let current = head
    let i = 1
    while i < 1000:
        set current.next = new Node(i)
        set current = current.next
        set i = i + 1
    echo "Deep list created, triggering GC"
    echo "GC test passed"

echo "--- STARTING STABILIZATION VERIFICATION ---"

test_exceptions()
test_gc()

try:
    test_recursion(1)
catch err:
    echo "Recursion limit caught: " + err

echo "--- VERIFICATION COMPLETE ---"
