// 02_fibonacci.vx
// Demonstrates recursion and arithmetic in VYRONIX

fn fib(n: i64) -> i64 {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

fn main() {
    let limit = 10;
    print("Fibonacci sequence up to {limit}:");
    
    for i = 0 to (limit) {
        let res = fib(i);
        print("fib({i}) = {res}");
    }
}

main();
