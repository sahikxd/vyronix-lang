unit heavyTask(id):
    echo "Starting task " + id
    time_sleep(1000)
    echo "Finished task " + id
    give id * 100

echo "Spawning async tasks..."
let t1 = spawn heavyTask(1)
let t2 = spawn heavyTask(2)

echo "Doing other work while tasks run..."

let res1 = await t1
let res2 = await t2

echo "Task 1 result: " + res1
echo "Task 2 result: " + res2
