{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "VYRONIX",
    "scopeName": "source.vx",
    "patterns": [
        { "include": "#comments" },
        { "include": "#namespaces" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" }
    ],
    "repository": {
        "namespaces": {
            "patterns": [
                {
                    "name": "entity.name.namespace.vx",
                    "match": "\\b(io|fs|str|arr|math|sys)\\b"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.vx",
                    "match": "//.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.vx",
                    "match": "\\b(fn|proc|let|var|const|if|elif|else|loop|for|to|step|match|case|default|try|catch|struct|enum|import|use|module|export|return|break|continue|BEGIN|END|call|assert|print|log)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.vx",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|int|float|bool|str|string|void|any|array)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.vx",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vx",
                            "match": "\\\\."
                        },
                        {
                            "name": "variable.other.interpolation.vx",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.vx",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.vx",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.vx",
                    "match": "\\b(true|false)\\b"
                }
            ]
        }
    }
}
